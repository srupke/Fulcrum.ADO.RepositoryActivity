{
  "manifestVersion": 1,
  "id": "fulcrum-repo-activity",
  "publisher": "ScottRupke",
  "version": "1.0.14",
  "name": "Fulcrum Repository Activity",
  "description": "Lists repositories with commits to the default branch since a selected date.",
  "public": true,
  "categories": ["Azure Repos"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "contributions": [
    {
      "id": "hub",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-code-web.code-hub-group"],
      "properties": {
        "name": "Repo Activity",
        "order": 99,
        "uri": "dist/hub/hub.html"
      }
    }
  ],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "overview.md",
      "assetType": "Microsoft.VisualStudio.Services.Content.Details",
      "addressable": true
    },
    {
      "path": "LICENSE",
      "assetType": "Microsoft.VisualStudio.Services.Content.License",
      "addressable": true
    },
    {
      "path": "privacy.md",
      "assetType": "Microsoft.VisualStudio.Services.Content.Privacy",
      "addressable": true
    }
  ],
  "scopes": [
    "vso.code"
  ],
  "license": "LICENSE",
  "links": {
    "repository": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryActivity"
    },
    "issues": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryActivity/issues"
    },
    "support": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryActivity/issues"
    },
    "license": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryActivity/blob/main/LICENSE"
    },
    "privacypolicy": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryActivity/blob/main/privacy.md"
    }
  }
}
