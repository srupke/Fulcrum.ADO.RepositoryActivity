{
  "manifestVersion": 1,
  "id": "fulcrum-repo-activity",
  "publisher": "ScottRupke",
  "version": "1.0.7",
  "name": "Fulcrum Repository Activity",
  "description": "Lists repositories with commits to the default branch since a selected date.",
  "public": true,
  "categories": ["Azure Repos"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "contributions": [
    {
      "id": "hub",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-code-web.code-hub-group"],
      "properties": {
        "name": "Repo Activity",
        "order": 99,
        "uri": "dist/hub/hub.html"
      }
    }
  ],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "overview.md",
      "assetType": "Microsoft.VisualStudio.Services.Content.Details"
    }
  ],
  "scopes": [
    "vso.code"
  ]
}
